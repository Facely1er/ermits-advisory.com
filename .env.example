# Gumroad Product URLs
# After creating products on Gumroad, replace these with your actual product URLs
# Format: https://gumroad.com/l/{your-unique-product-code}

# STEEL Premium Assessment ($29)
REACT_APP_GUMROAD_STEEL=https://gumroad.com/ermits/steel-premium

# vCISO Starter Kit ($299)
REACT_APP_GUMROAD_VCISO=https://gumroad.com/ermits/vciso-kit

# Executive Dashboard Template ($79)
REACT_APP_GUMROAD_DASHBOARD=https://gumroad.com/ermits/dashboard-template

# Analytics (Optional)
REACT_APP_ENABLE_ANALYTICS=true

# Feature Flags
REACT_APP_ENABLE_PREMIUM=true
