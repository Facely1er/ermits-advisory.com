# Application Configuration
VITE_APP_NAME=ERMITS Advisory
VITE_APP_URL=https://ermits-advisory.com
VITE_APP_VERSION=1.0.0

# Environment
NODE_ENV=development

# Analytics
VITE_VERCEL_ANALYTICS_ID=

# API Configuration (for future use)
VITE_API_BASE_URL=https://api.ermits-advisory.com
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PWA=true

# Development Settings
VITE_SHOW_DEV_TOOLS=false
VITE_LOG_LEVEL=info

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@ermits-advisory.com

# Download Security
DOWNLOAD_SECRET=your-secret-key-must-be-32-chars!

# Product File URLs (hosted file storage)
VCISO_KIT_URL=https://your-storage.com/vciso-kit.zip
DASHBOARD_TEMPLATE_URL=https://your-storage.com/dashboard-template.zip