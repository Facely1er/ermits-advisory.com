# =============================================================================
# ERMITS Advisory - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
VITE_APP_NAME=ERMITS Advisory
VITE_APP_URL=https://ermits-advisory.com
VITE_APP_VERSION=1.0.0
NODE_ENV=production

# -----------------------------------------------------------------------------
# Stripe Configuration (REQUIRED for payment functionality)
# -----------------------------------------------------------------------------
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_xxx) for development
# Use live keys (pk_live_xxx) for production

VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Product IDs (created via npm run create-stripe-products)
VITE_STRIPE_STEEL_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxx
VITE_STRIPE_VCISO_KIT_PRICE_ID=price_xxxxxxxxxxxxx
VITE_STRIPE_DASHBOARD_TEMPLATE_PRICE_ID=price_xxxxxxxxxxxxx

# Stripe Webhook Secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=https://api.ermits-advisory.com
VITE_API_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------
# Vercel Analytics (automatically configured on Vercel)
VITE_VERCEL_ANALYTICS_ID=

# Enable/disable analytics collection
VITE_ENABLE_ANALYTICS=true

# -----------------------------------------------------------------------------
# Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=

# Enable error reporting
VITE_ENABLE_ERROR_REPORTING=true

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable Progressive Web App features
VITE_ENABLE_PWA=true

# Enable demo/test data for development
VITE_ENABLE_DEMO_DATA=false

# -----------------------------------------------------------------------------
# Development Configuration
# -----------------------------------------------------------------------------
# Show development tools in UI
VITE_SHOW_DEV_TOOLS=false

# Logging level: 'error' | 'warn' | 'info' | 'debug'
VITE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# ERMITS Ecosystem URLs (for redirects)
# -----------------------------------------------------------------------------
VITE_CYBERCAUTION_URL=https://cybercaution.com
VITE_CYBERCORRECT_URL=https://cybercorrect.com
VITE_CYBERSOLUCE_URL=https://cybersoluce.com
VITE_VENDORSOLUCE_URL=https://vendorsoluce.com
VITE_TECHNOSOLUCE_URL=https://technosoluce.com
VITE_CYBERCERTITUDE_URL=https://cybercertitude.com
VITE_SOCIALCAUTION_URL=https://socialcaution.com

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for contact forms)
# -----------------------------------------------------------------------------
VITE_CONTACT_EMAIL=advisory@ermits.com
VITE_SUPPORT_EMAIL=support@ermits-advisory.com

# -----------------------------------------------------------------------------
# IMPORTANT NOTES:
# -----------------------------------------------------------------------------
# 1. Never commit .env file to git (it's in .gitignore)
# 2. Use test mode Stripe keys during development
# 3. Store production secrets in Vercel environment variables
# 4. Restart dev server after changing environment variables
# 5. Vite only exposes variables prefixed with VITE_ to the client
# 6. Server-side variables (like STRIPE_SECRET_KEY) should NOT have VITE_ prefix
# =============================================================================

